# Aegis-Q Environment Configuration Template
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ─── Database ──────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://aegis:aegis_secret@localhost:5433/aegisq

# ─── Cache ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Kafka ─────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_PARTITIONS=3
KAFKA_REPLICATION=1

# ─── Dataset ───────────────────────────────────────────────────────
DATASET_PATH=./dataset/r4.2
ANSWERS_PATH=./dataset/answers

# ─── Post-Quantum Cryptography ─────────────────────────────────────
# Set to "production" when liboqs is installed and verified
PQC_MODE=placeholder
PQC_KEY_DIR=./pqc_keys

# ─── Kafka Producer / Stream ───────────────────────────────────────
# REPLAY_SPEED: events per second. Use "inf" for maximum speed.
REPLAY_SPEED=inf
SAMPLE_MODE=true

# ─── API ───────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── Frontend (used in frontend/.env.local) ────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
