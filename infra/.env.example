# Copy this file to .env and customize for your local environment.
# WARNING: These values are for local development only. Do NOT commit real secrets.

# Postgres password used by the infra and backend
# Set this in your local `infra/.env` or the environment. DO NOT commit real secrets.
POSTGRES_PASSWORD=

# AES/GCM or Fernet key used to encrypt per-user TOTP secrets for local dev.
# Generate a key with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AEGIS_KEK=

# Demo TOTP override (development only)
DEMO_TOTP_CODE=123456
